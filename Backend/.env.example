APP_ENV=local
APP_DEBUG=true

# Driver soportado: mysql | pgsql | sqlite
DB_DRIVER=pgsql

# Opcion A (recomendada para Supabase): usar campos separados
DB_HOST=aws-1-eu-west-1.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.tu-project-ref
DB_PASSWORD=tu_password
DB_SSLMODE=require

# Opcion B: URL completa
# Nota: si la clave contiene @ u otros caracteres especiales, encodea la clave
# Ejemplo: p@ss -> p%40ss
# DB_URL=postgresql://postgres.tu-project-ref:tu_password@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# Solo aplica a MySQL
DB_CHARSET=utf8mb4

# Opcional: habilita API key obligatoria para todos los endpoints
# API_KEY=tu_api_key_segura
